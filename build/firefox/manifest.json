{
  "manifest_version": 3,
  "name": "Kufar.by Валюты",
  "version": "0.4.0",
  "description": "Замена цен на Kufar.by из BYN в выбранную валюту с курсами НБРБ.",
  "permissions": [
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "https://api.nbrb.by/*"
  ],
  "background": {
    "scripts": [
      "src/background.js"
    ],
    "type": "module"
  },
  "action": {
    "default_title": "Kufar.by Валюты",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.kufar.by/*"
      ],
      "js": [
        "src/content/kufar.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "kufar-by-currencies@redpandadev",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
