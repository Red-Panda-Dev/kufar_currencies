{
  "manifest_version": 3,
  "name": "Kufar.by Валюты",
  "version": "0.3.0",
  "description": "Замена цен на Kufar.by из BYN в выбранную валюту с курсами НБРБ.",
  "permissions": [
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "https://api.nbrb.by/*",
    "https://kufar.by/*",
    "https://*.kufar.by/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Kufar.by Валюты",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://kufar.by/*",
        "https://*.kufar.by/*"
      ],
      "js": [
        "content/kufar.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
